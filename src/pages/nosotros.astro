---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import galleryData from '../data/gallery-data.json';
import { Icon } from 'astro-icon/components';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Quiénes Somos - Formatos Intergraficos",
  "url": "https://formatosintergraficos.pe/nosotros",
  "description": "Imprenta autorizada SUNAT con más de 20 años de experiencia en Lima, Perú. Conoce los trabajos que hemos realizado para distintas empresas.",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "Formatos Intergraficos",
    "founder": {"@type": "Person", "name": "Zenón Walter Armas Quispialaya"},
    "foundingDate": "2004",
    "numberOfEmployees": {"@type": "QuantitativeValue", "minValue": 1, "maxValue": 10},
    "taxID": "20503580030",
    "url": "https://formatosintergraficos.pe"
  }
};

const stats = [
  { value: '20+', label: 'Años de experiencia' },
  { value: '5000+', label: 'Clientes satisfechos' },
  { value: '100%', label: 'Autorizado SUNAT' },
  { value: '24h', label: 'Entrega en Lima' }
];

const sectors = [
  'Transporte', 'Restaurantes', 'Farmacias', 'Bodegas',
  'Minería', 'Colegios', 'Notarías', 'Distribuidoras',
  'Agrario', 'Ferreterías'
];
---

<Layout 
  title="Nosotros | Formatos Intergraficos - Trabajos Realizados"
  description="Conoce la experiencia de Formatos Intergraficos: más de 20 años como imprenta autorizada SUNAT en Lima. Mira los trabajos que hemos realizado para distintas empresas del Perú."
>
  <Header />
  <main>
    <!-- HERO -->
    <section class="relative bg-gradient-to-br from-gray-50 via-white to-primary-50/40 pt-28 pb-16 lg:pt-32 lg:pb-20 overflow-hidden">
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100 rounded-full blur-3xl opacity-30 -mr-20 -mt-20 pointer-events-none"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col items-center text-center max-w-3xl mx-auto">
          <span class="inline-block text-xs font-semibold tracking-wider text-gray-600 uppercase mb-5 bg-white px-4 py-2 rounded-full border border-gray-200 shadow-sm">
            Formatos Intergraficos
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight leading-[1.1] mb-6">
            Detrás de cada formato,<br>
            <span class="text-primary-600">años de experiencia</span>
          </h1>
          <p class="text-lg lg:text-xl text-gray-600 leading-relaxed mb-10 max-w-2xl">
            Somos una imprenta autorizada SUNAT con más de 20 años trabajando para empresas de todo el Perú.
            Este es nuestro trabajo.
          </p>
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
          {stats.map(s => (
            <div class="bg-white/80 backdrop-blur-sm rounded-xl border border-gray-100 px-4 py-5 text-center shadow-sm">
              <div class="text-2xl md:text-3xl font-extrabold text-primary-600">{s.value}</div>
              <div class="text-xs md:text-sm text-gray-500 mt-1">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TRABAJOS REALIZADOS -->
    <section class="py-16 lg:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 tracking-tight">
            Trabajos que hemos realizado
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Empresas de distintos rubros confían en nosotros para sus formatos impresos. 
            Cada trabajo es un reflejo de nuestro compromiso con la calidad.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {galleryData.map(item => (
            <a
              href={`https://wa.me/51910500706?text=${encodeURIComponent('Hola, vi el trabajo de ' + item.title + ' en su web y me gustaría cotizar algo similar.')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group block bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
            >
              <div class="aspect-[4/3] overflow-hidden bg-gray-100">
                <img
                  src={item.image}
                  alt={item.alt}
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width="400"
                  height="300"
                />
              </div>
              <div class="p-5">
                <span class="inline-block text-xs font-semibold text-primary-600 bg-primary-50 px-2.5 py-1 rounded-full mb-2">
                  {item.category}
                </span>
                <h3 class="text-base font-bold text-gray-900 mb-1 group-hover:text-primary-600 transition-colors">
                  {item.title}
                </h3>
                <p class="text-sm text-gray-500">{item.client}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- RUBROS -->
    <section class="py-14 bg-gray-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8">
          Rubros que atendemos
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {sectors.map(s => (
            <span class="px-5 py-2.5 bg-white text-gray-700 rounded-full text-sm font-medium border border-gray-200 shadow-sm hover:border-primary-200 hover:text-primary-600 transition-colors cursor-default">
              {s}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 lg:py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          ¿Necesitas un trabajo similar?
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          Cuéntanos qué necesitas y te daremos una cotización en menos de 2 horas.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/51910500706" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-semibold text-lg px-8 py-4 rounded-xl shadow-lg shadow-primary-200 hover:shadow-xl transition-all">
            <Icon name="lucide:message-circle" class="w-5 h-5" />
            Cotizar por WhatsApp
          </a>
          <a href="/contacto#cotizar" class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-primary-600 font-semibold text-lg px-8 py-4 rounded-xl border-2 border-primary-600 transition-all">
            Formulario web
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}></script>
