---
export interface Props {
	title: string;
	description?: string;
}

const { title, description = "Impresión profesional de papel continuo, proformas y vouchers autorizados SUNAT para tu negocio. Entrega rápida, formatos legales y precios por volumen." } = Astro.props;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Formatos Intergraficos",
    "image": "https://formatosintergraficos.pe/LogoFormatos.webp",
    "@id": "https://formatosintergraficos.pe",
    "url": "https://formatosintergraficos.pe",
    "telephone": "+51910500706",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Pasaje 8 de octubre 252 - Parque Interno Hogar policial VMT",
      "addressLocality": "Lima",
      "addressRegion": "LMA",
      "postalCode": "15801",
      "addressCountry": "PE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -12.1611,
      "longitude": -76.9422
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "08:00",
      "closes": "20:00"
    },
    "taxID": "20503580030"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Formatos Intergraficos",
    "url": "https://formatosintergraficos.pe/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Qué necesito para imprimir boletas autorizadas SUNAT?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Solo necesitas haber gestionado tu autorización de impresión a través del Formulario Virtual N.° 816 en SUNAT. Si aún no lo has hecho, ¡nosotros te asesoramos en todo el proceso!"
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto tiempo tarda la entrega?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Una vez aprobado el diseño final (arte), tu pedido estará listo en un plazo de 3 días hábiles."
        }
      }
    ]
  }
];
---

<!doctype html>
<html lang="es">
	<head>
		
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="google-site-verification" content="yGbiXEjgzPGKiFddoCGN-8Qujk6GOmfHSostRQRjBKc" />
		<link rel="icon" type="image/png" href="/LogoFormatos.webp" />
		<link rel="sitemap" href="/sitemap.xml" />
		<meta name="theme-color" content="#ffffff" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="author" content="Formatos Intergraficos" />

		<!-- Local SEO -->
		<meta name="geo.region" content="PE-LMA" />
		<meta name="geo.placename" content="Lima" />
		<meta name="geo.position" content="-12.161;-76.942" />
		
		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:image" content={new URL("/MiniaturaFormatosIntergraficos.webp", Astro.site || Astro.url)} />
		<meta property="og:locale" content="es_PE" />
		<meta property="og:site_name" content="Formatos Intergraficos" />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL("/MiniaturaFormatosIntergraficos.webp", Astro.site || Astro.url)} />
		
		<!-- Canonical URL -->
		<link rel="canonical" href={Astro.url} />
		
		<!-- Preconnect to Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-XNJN3C82KP"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-XNJN3C82KP');
		</script>
		<!-- Schema JSON-LD -->
		<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}></script>
	</head>
	
	<body class="bg-white text-gray-900">
		<slot />

		<!-- WhatsApp Floating Button -->
		<div id="whatsapp-float" class="fixed bottom-5 right-5 z-50 flex flex-col items-end gap-3">
			<div id="whatsapp-tooltip" class="bg-white rounded-2xl shadow-xl border border-gray-100 p-4 max-w-[260px] text-sm opacity-0 scale-90 origin-bottom-right transition-all duration-200 pointer-events-none">
				<p class="text-gray-800 font-medium mb-1">¿Necesitas cotizar?</p>
				<p class="text-gray-500 text-xs">Respuesta rápida por WhatsApp</p>
				<div class="absolute -bottom-1.5 right-5 w-3 h-3 bg-white border-r border-b border-gray-100 rotate-45"></div>
			</div>
			<a
				href="https://wa.me/51910500706"
				target="_blank"
				rel="noopener noreferrer"
				id="whatsapp-btn"
				class="flex items-center justify-center w-14 h-14 bg-green-500 hover:bg-green-600 active:scale-95 text-white rounded-full shadow-lg shadow-green-400/40 hover:shadow-xl hover:shadow-green-400/50 transition-all duration-200"
				aria-label="Cotizar por WhatsApp"
			>
				<svg class="w-7 h-7" fill="white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
				</svg>
			</a>
		</div>

		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const btn = document.getElementById('whatsapp-btn');
				const tooltip = document.getElementById('whatsapp-tooltip');
				if (btn && tooltip) {
					const show = () => { tooltip.classList.remove('opacity-0', 'scale-90'); tooltip.classList.add('opacity-100', 'scale-100'); };
					const hide = () => { tooltip.classList.remove('opacity-100', 'scale-100'); tooltip.classList.add('opacity-0', 'scale-90'); };
					btn.addEventListener('mouseenter', show);
					btn.addEventListener('mouseleave', hide);
					setTimeout(show, 2000);
					setTimeout(hide, 7000);
				}
			});
		</script>
	</body>
</html>

<style is:global>
	@import '../styles/global.css';
</style>
